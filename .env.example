# ═══════════════════════════════════════════════════════════
# Hachi ERP — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hachi_erp"

# ─── Auth ────────────────────────────────────────────────
NEXTAUTH_SECRET="sua-chave-secreta-aqui-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── BotConversa (WhatsApp) ──────────────────────────────
BOTCONVERSA_API_KEY="sua-chave-webhook-integration"

# ─── Pix BACEN ───────────────────────────────────────────
PIX_BASE_URL="https://pix.exemplo.com.br/api/v2"
PIX_CLIENT_ID=""
PIX_CLIENT_SECRET=""
PIX_CERTIFICATE_PATH="./certs/pix.pem"
PIX_KEY="cnpj-ou-chave-aleatoria"

# ─── NF-e / NFS-e ───────────────────────────────────────
NFE_PROVIDER="nfeio"
NFE_API_KEY=""
NFE_BASE_URL="https://api.nfe.io/v1"
NFE_CNPJ=""
NFE_INSCRICAO_MUNICIPAL=""

# ─── Segurança ───────────────────────────────────────────
ENCRYPTION_KEY="chave-aes-256-bits-aqui"
